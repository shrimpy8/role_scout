# ─── API Keys (required) ──────────────────────────────────────────────────────

  ANTHROPIC_API_KEY=                             # Your Anthropic API key — used for scoring, reflection, and tailoring

  SERPAPI_KEY=               
                                      # SerpAPI key for the Google Jobs source
                                      # Free tier: 250 searches/month  |  serpapi.com

  APIFY_TOKEN=
                                      # Apify token for the LinkedIn scraper actor
                                      # Free tier covers typical usage  |  apify.com

  IMAP_HOST=imap.mail.yahoo.com
  IMAP_USER=                          # Email address that receives TrueUp job alert digests
  IMAP_PASSWORD=                      # App-specific password for that account (NOT your login password)
                                      # Yahoo: Settings → Security → App passwords
  IMAP_FOLDER=TrueUp                  # Mailbox folder where TrueUp emails land (default: INBOX)

  # ─── Dashboard ────────────────────────────────────────────────────────────────

  FLASK_SECRET_KEY=          
                                      # Random secret used to sign browser sessions and CSRF tokens
                                      # Generate: python -c "import secrets; print(secrets.token_hex(32))"
                                      # Keep this private — never commit it

  # ─── Scoring ──────────────────────────────────────────────────────────────────

  SCORE_THRESHOLD=70                  # Minimum match % (0–100) for a job to count as "qualified"
                                      # Jobs below this are scored but not saved or shown in the dashboard
                                      # 60 = broad net   |   70 = solid matches   |   85 = strict

  MAX_COST_USD=5.00                   # Per-run Claude API spend cap in USD
                                      # Scoring is skipped entirely if this is already exceeded when the node starts
                                      # A typical full run costs $0.10–$1.00 depending on job count

  # ─── Pipeline behaviour ───────────────────────────────────────────────────────

  RUN_MODE=agentic                    # Only supported value is "agentic"

  DISCOVERY_MAX_ITEMS=25              # Max jobs to fetch per source per run (1–200)
                                      # Lower = faster and cheaper  |  higher = broader coverage
                                      # Use 10–20 for test runs, 50 for normal use

  # ─── Human-in-the-loop (HiTL) ────────────────────────────────────────────────

  INTERRUPT_TTL_HOURS=4               # How long to wait for your Approve/Cancel before the run auto-cancels
                                      # If the window expires the run is logged as cancel_reason=ttl_expired

  TTL_EXTENSION_SECONDS=7200          # Extra time added when you click the "+2h extend" button (in seconds)
                                      # 7200 = 2 hours  |  you can extend once per run

  # ─── Storage ──────────────────────────────────────────────────────────────────

  DB_PATH=output/jobsearch.db         # SQLite database file — created automatically on first run
                                      # Use a different path for test runs to avoid touching production data:
                                      # DB_PATH=output/test.db

  CANDIDATE_PROFILE_PATH=config/candidate_profile.yaml   # Your job preferences — not committed, copy from config/example
  WATCHLIST_PATH=config/watchlist.yaml                   # Companies to highlight — not committed

  # ─── Claude model & pricing ───────────────────────────────────────────────────

  CLAUDE_MODEL=claude-sonnet-4-6     # Claude model used for scoring, reflection, and tailoring
                                     # Update when Anthropic releases a newer model

  CLAUDE_INPUT_COST_PER_MTOK=3.0     # Cost per million input tokens (USD) — used for run cost estimates only
  CLAUDE_OUTPUT_COST_PER_MTOK=15.0   # Cost per million output tokens (USD)
                                     # Update these if Anthropic changes pricing

  # ─── Observability ────────────────────────────────────────────────────────────

  LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
                               # DEBUG shows per-job scores and Claude prompt previews
                               # Use INFO for normal operation

  # Optional: LangSmith graph tracing (leave commented out unless you need it)
  # LANGSMITH_TRACING=true
  # LANGSMITH_API_KEY=
  # LANGSMITH_PROJECT=role_scout