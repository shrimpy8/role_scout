# === Required ===
ANTHROPIC_API_KEY=your-anthropic-api-key
SERPAPI_KEY=your-serpapi-key
APIFY_TOKEN=your-apify-token

# === Required for eval (cross-model judge) ===
# Either OPENAI_API_KEY or GOOGLE_API_KEY
OPENAI_API_KEY=your-openai-key
# GOOGLE_API_KEY=your-google-key

# === Required for TrueUp source ===
IMAP_EMAIL=your-gmail@gmail.com
IMAP_APP_PASSWORD=your-app-password

# === Pipeline tuning (all have safe defaults) ===
SCORE_THRESHOLD=85
REFLECTION_ENABLED=true
# Pipeline mode: linear | agentic | shadow (default: shadow for first 2 weeks)
RUN_MODE=shadow
MAX_COST_USD=5.00
INTERRUPT_TTL_HOURS=4.0
REFLECTION_BAND_LOW=70
REFLECTION_BAND_HIGH=89
SERPAPI_MIN_QUOTA=10
SOURCE_HEALTH_WINDOW=3

# === Paths (relative to repo root) ===
DB_PATH=../auto_jobsearch/output/jobsearch.db
WATCHLIST_PATH=../auto_jobsearch/config/watchlist.yaml
RESUME_SUMMARY_PATH=../auto_jobsearch/config/resume_summary.md
CANDIDATE_PROFILE_PATH=../auto_jobsearch/config/candidate_profile.yaml
JD_OUTPUT_DIR=../auto_jobsearch/output/jds

# === Observability ===
LOG_LEVEL=INFO
LOG_FILE=logs/role_scout.log
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_PROJECT=role_scout

# === Flask ===
FLASK_SECRET_KEY=change-me-to-a-random-secret
